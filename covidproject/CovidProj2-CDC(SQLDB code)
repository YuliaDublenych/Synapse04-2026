--CDC output check
DECLARE @from_lsn VARBINARY(10),
        @to_lsn   VARBINARY(10);

SET @from_lsn = sys.fn_cdc_get_min_lsn('dbo_Patient');
SET @to_lsn   = sys.fn_cdc_get_max_lsn();

SELECT *
FROM cdc.fn_cdc_get_all_changes_dbo_Patient(@from_lsn, @to_lsn, 'all update old')
ORDER BY __$start_lsn, __$seqval;
GO


--enable cdc on db and table level

EXEC sys.sp_cdc_enable_db;
GO

EXEC sys.sp_cdc_enable_table
    @source_schema = N'dbo',
    @source_name   = N'Patient',
    @role_name     = NULL,
    @supports_net_changes = 1;
